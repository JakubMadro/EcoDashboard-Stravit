# =====================================================================
# EcoDashboard Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# DO NOT commit '.env' to git!
# =====================================================================

# Azure Table Storage connection string (used by app and scripts locally)
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;TableEndpoint=..."

# Connection strings for the migration script (scripts/migrate_prod_to_dev.py)
PROD_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;TableEndpoint=..."
DEV_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;TableEndpoint=..."

# Optional: Master credentials to log in to Stravit (used by daemon and backfill script)
STRAVIT_EMAIL="your_email@example.com"
STRAVIT_PASSWORD="your_stravit_password"

# Local Server Settings
PORT=8000
SYNC_RATE_LIMIT_MINUTES=30
